# ── Database ──────────────────────────────────────────────────────────────────
# Either set DATABASE_URL directly (takes precedence):
# DATABASE_URL=postgresql://user:pass@host:5432/decision_engine
#
# Or set individual POSTGRES_* vars:

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=decision_engine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production. Startup fails if unset when API_ENV=production.
JWT_SECRET=replace-this-with-a-long-random-string

# ── Notifications ─────────────────────────────────────────────────────────────
# Telegram bot integration (optional; disabled when not set)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Exchange Keys ─────────────────────────────────────────────────────────────
# Hyperliquid API credentials (optional; some features use Hyperliquid collector)
HL_API_KEY=
HL_SECRET=

# ── Environment ───────────────────────────────────────────────────────────────
# API_ENV=production  # uncomment for JSON structured logging
# DEBUG=false