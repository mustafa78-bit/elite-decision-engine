# ── Environment ──────────────────────────────────────────────────────────────
API_ENV=development
APP_VERSION=0.9.0
DEBUG=false
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────────────────
# Either set DATABASE_URL directly (takes precedence):
# DATABASE_URL=postgresql://user:pass@host:5432/decision_engine
#
# Or set individual POSTGRES_* vars:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=decision_engine
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. Startup fails if unset when API_ENV=production.
JWT_SECRET=replace-this-with-a-long-random-string-at-least-32-chars

# ── Encryption ───────────────────────────────────────────────────────────────
# Used for encrypting sensitive data at rest. Must be 32 bytes (44 chars base64).
# ENCRYPTION_KEY=

# ── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGIN_REGEX=r'^https?://localhost(:\d+)?$'

# ── Risk Limits ──────────────────────────────────────────────────────────────
# CHECK_INTERVAL=10
# MIN_SCORE=85
# MAX_OPEN_TRADES=3
# MAX_EXPOSURE_PER_SYMBOL=200000
# MAX_PORTFOLIO_EXPOSURE=500000
# MAX_DAILY_LOSS=10000
# MAX_POSITION_SIZE_USD=100000
# ACCOUNT_EQUITY=10000
# RISK_PER_TRADE_PERCENT=1.0
# ATR_MULTIPLIER=1.5
# MIN_POSITION_QUANTITY=0.001

# ── Notifications ────────────────────────────────────────────────────────────
# Telegram bot integration (optional; disabled when not set)
# TELEGRAM_TOKEN=
# TELEGRAM_CHAT_ID=

# ── AI Provider ──────────────────────────────────────────────────────────────
# NVIDIA NIM (OpenAI-compatible) API key
# NVIDIA_API_KEY=
#
# AI provider type: "nvidia" (more to come)
# AI_PROVIDER=nvidia
#
# AI model override (e.g. "meta/llama3-70b-instruct")
# AI_MODEL=
#
# NVIDIA NIM base URL (default: https://integrate.api.nvidia.com/v1)
# NVIDIA_BASE_URL=

# ── Exchange Keys ────────────────────────────────────────────────────────────
# Hyperliquid API credentials (optional; some features use Hyperliquid collector)
# HL_API_KEY=
# HL_SECRET=
